@{
    var stats = (AdminDashboardViewModel)ViewBag.Stats;
    ViewData["Title"] = "Admin — Dashboard";
}

@section Styles {
    <link rel="stylesheet" href="~/css/admin.css" />
}

<div class="admin-layout">
    @await Html.PartialAsync("Sidebar", "index")

    <main class="admin-main">
        <h1 class="admin-page-title">
            Dashboard
            <span class="admin-page-subtitle">Linkora admin panel</span>
        </h1>

        <!-- Stats grid -->
        <div class="admin-stats-grid">
            <div class="admin-stat-card">
                <div class="admin-stat-icon admin-stat-icon-blue">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/>
                        <path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>
                    </svg>
                </div>
                <div class="admin-stat-value">@stats.TotalUsers</div>
                <div class="admin-stat-label">Total users</div>
                @if (stats.NewUsersToday > 0)
                {
                    <div class="admin-stat-delta">+@stats.NewUsersToday today</div>
                }
            </div>

            <div class="admin-stat-card">
                <div class="admin-stat-icon admin-stat-icon-teal">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                        <polyline points="14 2 14 8 20 8"/>
                    </svg>
                </div>
                <div class="admin-stat-value">@stats.ActiveProducts</div>
                <div class="admin-stat-label">Active listings</div>
                @if (stats.NewProductsToday > 0)
                {
                    <div class="admin-stat-delta">+@stats.NewProductsToday today</div>
                }
            </div>

            <div class="admin-stat-card">
                <div class="admin-stat-icon admin-stat-icon-orange">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <circle cx="12" cy="12" r="10"/>
                        <line x1="12" y1="8" x2="12" y2="12"/>
                        <line x1="12" y1="16" x2="12.01" y2="16"/>
                    </svg>
                </div>
                <div class="admin-stat-value">@stats.PendingModeration</div>
                <div class="admin-stat-label">Pending moderation</div>
                @if (stats.PendingModeration > 0)
                {
                    <div class="admin-stat-delta admin-stat-delta-warn">Needs review</div>
                }
            </div>

            <div class="admin-stat-card">
                <div class="admin-stat-icon admin-stat-icon-red">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/>
                        <line x1="12" y1="9" x2="12" y2="13"/>
                        <line x1="12" y1="17" x2="12.01" y2="17"/>
                    </svg>
                </div>
                <div class="admin-stat-value">@stats.PendingReports</div>
                <div class="admin-stat-label">Pending reports</div>
                @if (stats.PendingReports > 0)
                {
                    <div class="admin-stat-delta admin-stat-delta-warn">Needs review</div>
                }
            </div>
        </div>

        <!-- Charts -->
        <div class="admin-charts-grid">
            <div class="admin-card">
                <div class="admin-card-header">
                    <h2 class="admin-card-title">New users (7 days)</h2>
                </div>
                <div style="padding:16px 20px">
                    <canvas id="chartUsers" height="130"></canvas>
                </div>
            </div>
            <div class="admin-card">
                <div class="admin-card-header">
                    <h2 class="admin-card-title">New listings (7 days)</h2>
                </div>
                <div style="padding:16px 20px">
                    <canvas id="chartProducts" height="130"></canvas>
                </div>
            </div>
        </div>

        <!-- Products by status -->
        <div class="admin-card" style="margin-bottom:20px">
            <div class="admin-card-header">
                <h2 class="admin-card-title">Listings by status</h2>
            </div>
            <div style="display:flex;gap:0;padding:16px 20px;flex-wrap:wrap;gap:24px">
                @{
                    var statusColors = new Dictionary<string, string>
                    {
                        ["Active"]     = "#388e3c",
                        ["Moderation"] = "#f57c00",
                        ["Rejected"]   = "#c62828",
                        ["Archived"]   = "#757575",
                        ["Succeeded"]  = "#1565c0",
                    };
                    var total = stats.ProductsByStatus.Values.Sum();
                }
                @foreach (var (status, count) in stats.ProductsByStatus.OrderByDescending(x => x.Value))
                {
                    var color = statusColors.TryGetValue(status, out var c) ? c : "#aaa";
                    var pct = total > 0 ? (int)(count * 100.0 / total) : 0;
                    <div style="display:flex;flex-direction:column;gap:4px;min-width:120px">
                        <div style="font-size:20px;font-weight:700;color:#1a1a1a">@count</div>
                        <div style="height:4px;border-radius:2px;background:@color;width:@(Math.Max(pct,4))%"></div>
                        <div style="font-size:12px;color:#888">@status (@pct%)</div>
                    </div>
                }
            </div>
        </div>

        <!-- Recent products -->
        <div class="admin-card">
            <div class="admin-card-header">
                <h2 class="admin-card-title">Recent listings</h2>
                <a class="admin-card-link" href="/Admin/Products">View all →</a>
            </div>
            <table class="admin-table">
                <thead>
                    <tr>
                        <th>Product</th>
                        <th>Seller</th>
                        <th>Status</th>
                        <th>Date</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var p in stats.RecentProducts)
                    {
                        <tr>
                            <td>
                                <a href="/Product/Details/@p.Id" target="_blank"
                                   class="admin-table-product-name">@p.Name</a>
                            </td>
                            <td style="color:#666">@p.UserName</td>
                            <td>
                                <span class="admin-badge admin-badge-@p.Status.ToLower()">@p.Status</span>
                            </td>
                            <td style="color:#aaa;font-size:12px">@(p.CreatedTime?.ToString("dd MMM, HH:mm"))</td>
                            <td>
                                <a href="/Product/Details/@p.Id" target="_blank" class="admin-btn admin-btn-view">View</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </main>
</div>

@section Scripts {
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.0/chart.umd.min.js"></script>
<script>
(async () => {
    const res  = await fetch('/Admin/StatsApi');
    const data = await res.json();

    const cfg = (labels, values, color, label) => ({
        type: 'bar',
        data: {
            labels,
            datasets: [{ label, data: values, backgroundColor: color + '33',
                borderColor: color, borderWidth: 2, borderRadius: 4 }]
        },
        options: {
            responsive: true, maintainAspectRatio: false,
            plugins: { legend: { display: false } },
            scales: {
                y: { beginAtZero: true, ticks: { precision: 0, font: { size: 11 } },
                     grid: { color: '#f0f0f0' } },
                x: { ticks: { font: { size: 11 } }, grid: { display: false } }
            }
        }
    });

    // Fill missing days
    const days = [];
    for (let i = 6; i >= 0; i--) {
        const d = new Date(); d.setDate(d.getDate() - i);
        days.push(d.toLocaleDateString('en-GB', { day:'2-digit', month:'short' }));
    }
    const fill = (arr) => days.map(d => {
        const found = arr.find(x => x.day === d);
        return found ? found.count : 0;
    });

    new Chart(document.getElementById('chartUsers'), cfg(days, fill(data.registrations), '#1976d2', 'Users'));
    new Chart(document.getElementById('chartProducts'), cfg(days, fill(data.products), '#00b0a3', 'Listings'));
})();
</script>
}
