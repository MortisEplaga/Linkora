@model string
@{
    var pendingMod = 0;
    var pendingRep = 0;
    // Quick counts for badges - passed from each action if needed
    if (ViewBag.PendingModeration != null) pendingMod = (int)ViewBag.PendingModeration;
    if (ViewBag.PendingReports != null) pendingRep = (int)ViewBag.PendingReports;
}

<aside class="admin-sidebar">
    <div class="admin-sidebar-title">Admin Panel</div>

    <a class="admin-nav-link @(Model == "index" ? "active" : "")" href="/Admin/Index">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/>
            <rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/>
        </svg>
        Dashboard
    </a>

    <a class="admin-nav-link @(Model == "products" ? "active" : "")" href="/Admin/Products">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
            <polyline points="14 2 14 8 20 8"/>
        </svg>
        Listings
        @if (pendingMod > 0)
        {
            <span class="admin-nav-badge admin-nav-badge-warn">@pendingMod</span>
        }
    </a>

    <a class="admin-nav-link @(Model == "users" ? "active" : "")" href="/Admin/Users">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/>
            <path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>
        </svg>
        Users
    </a>

    <a class="admin-nav-link @(Model == "reports" ? "active" : "")" href="/Admin/Reports">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/>
            <line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/>
        </svg>
        Reports
        @if (pendingRep > 0)
        {
            <span class="admin-nav-badge">@pendingRep</span>
        }
    </a>

    <div style="margin-top:auto;padding:16px 20px;border-top:1px solid #222;margin-top:24px">
        <a href="/" style="font-size:13px;color:#555;text-decoration:none;display:flex;align-items:center;gap:8px">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="15 18 9 12 15 6"/>
            </svg>
            Back to site
        </a>
    </div>
</aside>
