@using Linkora.Models
@{
    var seller = (SellerViewModel)ViewBag.Seller;
    var products = (List<Product>)ViewBag.Products;
    var reviewCount = (int)ViewBag.ReviewCount;
    var reviewAvg = (double)ViewBag.ReviewAvg;
    var sort = (string)ViewBag.Sort;
    var activeCatId = (int?)ViewBag.CategoryId;
    var categories = (List<CategoryCount>)ViewBag.Categories;
    ViewData["Title"] = seller.UserName;
}

@section Styles {
    <link rel="stylesheet" href="~/css/Category.css" />
}

<!-- Шапка продавца -->
<div class="seller-header">
    <div class="seller-header-avatar">
        @if (seller.AvatarPath != null)
        {
            <img src="@seller.AvatarPath" onerror="this.src='/img/no-photo.svg'" />
        }
        else
        {
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#ccc" stroke-width="1.5">
                <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
                <circle cx="12" cy="7" r="4" />
            </svg>
        }
    </div>
    <div class="seller-header-info">
        <div class="seller-header-name">
            @seller.UserName
            @if (seller.IsCompany)
            {
                <span class="seller-badge">Company</span>
            }
        </div>
        @if (reviewCount > 0)
        {
            <button class="seller-header-rating" onclick="openReviews()">
                <span class="seller-stars">
                    @for (int i = 1; i <= 5; i++)
                    {
                        <svg width="16" height="16" viewBox="0 0 24 24"
                             fill="@(i <= Math.Round(reviewAvg) ? "#f5a623" : "none")"
                             stroke="#f5a623" stroke-width="2">
                            <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2" />
                        </svg>
                    }
                </span>
                <span class="seller-rating-val">@reviewAvg.ToString("F1")</span>
                <span class="seller-rating-count" data-i18n="ratings_label">Ratings: @reviewCount</span>
            </button>
        }
        <div class="seller-header-meta" data-i18n="member_since_label">
            Member since @(seller.CreatedAt?.ToString("MMMM yyyy") ?? "—")
        </div>
    </div>
    <div class="seller-header-actions">
        <button class="seller-share-btn" onclick="navigator.clipboard.writeText(window.location.href)" title="Share" data-i18n-title="share">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="18" cy="5" r="3" />
                <circle cx="6" cy="12" r="3" />
                <circle cx="18" cy="19" r="3" />
                <line x1="8.59" y1="13.51" x2="15.42" y2="17.49" />
                <line x1="15.41" y1="6.51" x2="8.59" y2="10.49" />
            </svg>
        </button>
        <button class="seller-subscribe-btn" data-i18n="subscribe_btn">Subscribe</button>
    </div>
</div>

<div class="category-body">
    <!-- Сайдбар -->
    <div class="category-left">
        <nav class="category-sidebar">
            <a class="sidebar-current @(activeCatId == null ? "sidebar-item-active" : "")"
               href="/Seller/Index/@seller.Id?sort=@sort" data-i18n="all_categories_side">
                All categories
            </a>
            @foreach (var cat in categories)
            {
                <a class="sidebar-child @(activeCatId == cat.Id ? "sidebar-item-active" : "")"
                   href="/Seller/Index/@seller.Id?categoryId=@cat.Id&sort=@sort">
                    @cat.Name
                    <span class="sidebar-cat-count">@cat.Count</span>
                </a>
            }
        </nav>
    </div>

    <!-- Контент -->
    <div class="category-content">
        <div class="listing-toolbar">
            <div class="listing-view-btns">
                <button class="listing-view-btn" id="btnGrid" onclick="setView('grid')" title="Grid">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <rect x="3" y="3" width="7" height="7" />
                        <rect x="14" y="3" width="7" height="7" />
                        <rect x="3" y="14" width="7" height="7" />
                        <rect x="14" y="14" width="7" height="7" />
                    </svg>
                </button>
                <button class="listing-view-btn" id="btnList" onclick="setView('list')" title="List">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <line x1="3" y1="6" x2="21" y2="6" />
                        <line x1="3" y1="12" x2="21" y2="12" />
                        <line x1="3" y1="18" x2="21" y2="18" />
                    </svg>
                </button>
            </div>
            <div class="listing-sort-wrap">
                <button class="listing-sort-btn" onclick="toggleSort(event)">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <line x1="3" y1="6" x2="21" y2="6" />
                        <line x1="7" y1="12" x2="21" y2="12" />
                        <line x1="11" y1="18" x2="21" y2="18" />
                    </svg>
                    <span id="sortLabel" data-sort="@sort">@(sort == "cheap" ? "Cheapest first" : sort == "expensive" ? "Most expensive" : "Newest first")</span>                    ▾
                </button>
                <div class="listing-sort-drop" id="sortDrop">
                    <a class="listing-sort-item @(sort == "new" ? "active" : "")"
                       href="/Seller/Index/@seller.Id?@(activeCatId.HasValue ? $"categoryId={activeCatId}&" : "")sort=new">Newest first</a>
                    <a class="listing-sort-item @(sort == "cheap" ? "active" : "")"
                       href="/Seller/Index/@seller.Id?@(activeCatId.HasValue ? $"categoryId={activeCatId}&" : "")sort=cheap">Cheapest first</a>
                    <a class="listing-sort-item @(sort == "expensive" ? "active" : "")"
                       href="/Seller/Index/@seller.Id?@(activeCatId.HasValue ? $"categoryId={activeCatId}&" : "")sort=expensive">Most expensive</a>
                </div>
            </div>
        </div>

        <div class="listing-grid" id="listingContainer">
            @foreach (var p in products)
            {
                <a class="product-card" asp-controller="Product" asp-action="Details" asp-route-id="@p.Id">
                    <div class="product-card-img">
                        <img src="@(p.AvatarImagePath ?? "/img/no-photo.svg")" alt="@p.Name"
                             onerror="this.src='/img/no-photo.svg'" />
                    </div>
                    <div class="product-card-body">
                        <div class="product-card-price">
                            @(p.Price.HasValue? p.Price.Value.ToString("N2") + " €" : "0 €")
                        </div>
                        <div class="product-card-name">@p.Name</div>
                        <div class="product-card-address">@p.Address</div>
                        <div class="product-card-date">@(p.CreatedTime?.ToString("dd MMM, HH:mm"))</div>
                    </div>
                </a>
            }
        </div>
    </div>
</div>

<!-- Модалка отзывов -->
<div class="reviews-overlay" id="reviewsOverlay" onclick="closeReviews()"></div>
<div class="reviews-modal" id="reviewsModal">
    <div class="reviews-modal-header">
        <span class="reviews-modal-title" data-i18n="reviews_title">Reviews</span>
        <button class="reviews-modal-close" onclick="closeReviews()">✕</button>
    </div>

    @if (reviewCount > 0)
    {
        <div class="reviews-summary">
            <div class="reviews-avg">@reviewAvg.ToString("F0")</div>
            <div>
                <div class="reviews-stars-big">
                    @for (int i = 1; i <= 5; i++)
                    {
                        <svg width="22" height="22" viewBox="0 0 24 24"
                             fill="@(i <= Math.Round(reviewAvg) ? "#f5a623" : "none")"
                             stroke="#f5a623" stroke-width="2">
                            <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2" />
                        </svg>
                    }
                </div>
                <div class="reviews-total">@reviewCount <span data-i18n="ratings_count">ratings</span></div>
            </div>
            <div class="reviews-bars">
                @{
                    var allReviews = (IEnumerable<dynamic>)ViewBag.Reviews;
                    var ratingGroups = allReviews
                    .GroupBy((dynamic r) => (int)r.Rating)
                    .ToDictionary(g => g.Key, g => g.Count());
                }
                @for (int star = 5; star >= 1; star--)
                {
                    var cnt = ratingGroups.TryGetValue(star, out var c) ? c : 0;
                    var pct = reviewCount > 0 ? (int)(cnt * 100.0 / reviewCount) : 0;
                    <div class="reviews-bar-row">
                        <div class="reviews-bar-track">
                            <div class="reviews-bar-fill" style="width:@pct%"></div>
                        </div>
                        <span class="reviews-bar-count">@cnt</span>
                    </div>
                }
            </div>
        </div>
    }

    <div class="reviews-list">
        @foreach (var r in (IEnumerable<dynamic>)ViewBag.Reviews)
        {
            <div class="review-item">
                <div class="review-author">
                    @if (r.AuthorAvatar != null)
                    {
                        <img src="@r.AuthorAvatar" class="review-author-avatar"
                             onerror="this.src='/img/no-photo.svg'" />
                    }
                    else
                    {
                        <div class="review-author-avatar review-author-placeholder">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#ccc" stroke-width="2">
                                <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
                                <circle cx="12" cy="7" r="4" />
                            </svg>
                        </div>
                    }
                    <div>
                        <div class="review-author-name">@r.AuthorName</div>
                        <div class="review-date">@(((DateTime)r.CreatedAt).ToString("dd.MM.yyyy"))</div>
                    </div>
                </div>
                <div class="review-stars">
                    @for (int i = 1; i <= 5; i++)
                    {
                        <svg width="14" height="14" viewBox="0 0 24 24"
                             fill="@(i <= (int)r.Rating ? "#f5a623" : "none")"
                             stroke="#f5a623" stroke-width="2">
                            <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2" />
                        </svg>
                    }
                </div>
                @if (!string.IsNullOrEmpty((string)r.Comment))
                {
                    <div class="review-comment">@r.Comment</div>
                }
            </div>
        }
        @if (reviewCount == 0)
        {
            <div class="reviews-empty" data-i18n="no_reviews_yet">No reviews yet</div>
        }
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const v = localStorage.getItem('listingView') || 'grid';
        setView(v);
    });

    function setView(v) {
        localStorage.setItem('listingView', v);
        const c = document.getElementById('listingContainer');
        c.className = v === 'grid' ? 'listing-grid' : 'listing-list';
        document.getElementById('btnGrid').classList.toggle('active', v === 'grid');
        document.getElementById('btnList').classList.toggle('active', v === 'list');
    }

    function toggleSort(e) {
        e.stopPropagation();
        document.getElementById('sortDrop').classList.toggle('open');
    }

    document.addEventListener('click', e => {
        if (!e.target.closest('.listing-sort-wrap'))
            document.getElementById('sortDrop').classList.remove('open');
    });

    function openReviews() {
        document.getElementById('reviewsOverlay').classList.add('open');
        document.getElementById('reviewsModal').classList.add('open');
    }

    function closeReviews() {
        document.getElementById('reviewsOverlay').classList.remove('open');
        document.getElementById('reviewsModal').classList.remove('open');
    }
</script>
