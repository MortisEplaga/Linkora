@using Linkora.Models
@{
    var products = (List<Product>)ViewBag.Products;
    var tab = (string)ViewBag.Tab;
    var counts = ViewBag.StatusCounts as Dictionary<string, int>;

   ViewData["Title"] = "My ads";

    var tabs = new[] {
        ("Active",      "Active"),
        ("Moderation",  "Under moderation"),
        ("Rejected",    "Rejected"),
        ("Archived",    "Archived"),
        ("Succeeded",   "Succeeded"),
    };
}

@section Styles {
    <link rel="stylesheet" href="~/css/myads.css" />
}

<div class="myads-page">
    <h1 class="myads-title">My ads</h1>

    <div class="myads-tabs">
        @foreach (var (key, label) in tabs)
        {
            <a class="myads-tab @(tab == key ? "myads-tab-active" : "")" href="?tab=@key">
                @label
                @if (counts.TryGetValue(key, out var count) && count > 0)
                {
                    <span class="myads-tab-count">@count</span>
                }
            </a>
        }
    </div>

    @if (!products.Any())
    {
        <div class="myads-empty">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#ccc" stroke-width="1.5">
                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
                <polyline points="14 2 14 8 20 8" />
                <line x1="16" y1="13" x2="8" y2="13" />
                <line x1="16" y1="17" x2="8" y2="17" />
            </svg>
            <p data-i18n="no_ads_yet">You have no @(tab == "active" ? "active" : "") ads yet.</p>
            <a class="myads-create-btn" asp-controller="Product" asp-action="Create">
                + Post an ad
            </a>
        </div>
    }
    else
    {
        <div class="myads-list">
            @foreach (var p in products)
            {
                <div class="myads-card">
                    <a asp-controller="Product" asp-action="Details" asp-route-id="@p.Id" class="myads-card-img">
                        <img src="@(p.AvatarImagePath ?? "/img/no-photo.svg")"
                             onerror="this.src='/img/no-photo.svg'" alt="@p.Name" />
                    </a>
                    <div class="myads-card-body">
                        <a class="myads-card-name" asp-controller="Product" asp-action="Details" asp-route-id="@p.Id">@p.Name</a>
                        <div class="myads-card-price">@(p.Price.HasValue? p.Price.Value.ToString("N2") + " €" : "Price on request")</div>
                        <div class="myads-card-meta">@p.Address · @(p.CreatedTime?.ToString("dd MMM, HH:mm"))</div>
                    </div>
                    <div class="myads-card-stats">
                        <div class="myads-stat">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" />
                                <circle cx="12" cy="12" r="3" />
                            </svg>
                            <span>@p.ViewCount</span>
                        </div>
                        <div class="myads-stat">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z" />
                            </svg>
                            <span>@p.FavCount</span>
                        </div>
                        <div class="myads-stat">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <circle cx="9" cy="21" r="1" />
                                <circle cx="20" cy="21" r="1" />
                                <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6" />
                            </svg>
                            <span>@p.CartCount</span>
                        </div>
                    </div>
                    <div class="myads-card-actions">
                        @if (p.Status == ProductStatus.Active)
                        {
                            <button class="myads-action-btn myads-action-complete"
                                    title="Complete deal"
                                    onclick="openPartnerModal(@p.Id)">
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <polyline points="20 6 9 17 4 12" />
                                </svg>
                            </button>
                        }
                        <a class="myads-action-btn" asp-controller="Product" asp-action="Edit" asp-route-id="@p.Id" data-i18n="edit_btn">Edit</a>
                        <button class="myads-action-btn myads-action-danger" onclick="deleteAd(@p.Id)" data-i18n="delete_btn">
                            Delete
                        </button>
                    </div>
                </div>
            }
        </div>
    }
</div>
<div class="modal-overlay" id="partnerOverlay" onclick="closePartnerModal()"></div>
<div class="modal" id="partnerModal">
    <button class="modal-close" onclick="closePartnerModal()">✕</button>
    <h2 class="auth-title" data-i18n="select_user">Select user</h2>
    <div class="partner-list" id="partnerList"></div>
    <div class="auth-actions" style="margin-top:16px;">
        <button class="auth-submit" onclick="closePartnerModal()">Cancel</button>
    </div>
</div>
<script>
        let currentProductId = null;

    function openPartnerModal(productId) {
        currentProductId = productId;
        fetch(`/Product/GetConversationPartners?productId=${productId}`)
            .then(res => res.json())
            .then(partners => {
                const list = document.getElementById('partnerList');
                list.innerHTML = '';
                if (partners.length === 0) {
                    list.innerHTML = `<div class="partner-item">${t('no_partners')}</div>`;
                    return;
                }
                partners.forEach(p => {
                    const item = document.createElement('div');
                    item.className = 'partner-item';
                    item.onclick = () => selectPartner(p.id);
                    item.innerHTML = `
                        <img class="partner-item-avatar" src="${p.avatarImagePath || '/img/no-photo.svg'}" onerror="this.src='/img/no-photo.svg'">
                        <span class="partner-item-name">${p.userName}</span>
                        ${p.isCompany ? '<span class="partner-item-badge">Company</span>' : ''}
                    `;
                    list.appendChild(item);
                });
            });
        document.getElementById('partnerOverlay').classList.add('modal-open');
        document.getElementById('partnerModal').classList.add('modal-open');
    }

    function closePartnerModal() {
        document.getElementById('partnerOverlay').classList.remove('modal-open');
        document.getElementById('partnerModal').classList.remove('modal-open');
    }

    async function selectPartner(otherUserId) {
        closePartnerModal();
        try {
            const res = await fetch(`/Product/CompleteDeal?id=${currentProductId}&otherUserId=${otherUserId}`, {
                method: 'POST',
                headers: {
                    'RequestVerificationToken': document.getElementById('afToken')?.value ?? ''
                }
            });
            if (res.ok) {
                location.reload();
            } else {
                const err = await res.text();
                console.error('Ошибка:', err);
                alert('Error: ' + err);
            }
        } catch (e) {
            console.error('Ошибка сети:', e);
        }
    }
    async function completeDeal(id) {
        try {
            const res = await fetch(`/Product/CompleteDeal?id=${id}`, {
                method: 'POST',
                headers: { 'RequestVerificationToken': document.getElementById('afToken')?.value ?? '' }
            });
            if (res.ok) location.reload();
            else console.error('Ошибка:', await res.text());
        } catch (e) { console.error('Ошибка сети:', e); }
    }

    async function deleteAd(id) {
        if (!confirm(t('confirm_delete'))) return;
        await fetch(`/Product/Delete?id=${id}`, {
            method: 'POST',
            headers: { 'RequestVerificationToken': document.getElementById('afToken')?.value ?? '' }
        });
        location.reload();
    }
</script>