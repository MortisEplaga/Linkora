@using Linkora.Models
@{
    var p = (Product)ViewBag.Product;
    var similar = (List<Product>)ViewBag.Similar;
    ViewData["Title"] = p.Name;
}

@section Styles {
    <link rel="stylesheet" href="~/css/details.css" />
}

<div class="details-page">

    <!-- Основной блок -->
    <div class="details-main">

        <!-- Фото -->
        @{
            var mediaList = p.Media.Count > 0
            ? p.Media
            : (p.AvatarImagePath != null
            ? new List<ProductMedia> { new() { FilePath = p.AvatarImagePath, MediaType = "image" } }
            : new List<ProductMedia> { new() { FilePath = "/img/no-photo.svg", MediaType = "image" } });
        }
        <div class="details-gallery">
            @if (mediaList[0].MediaType == "video")
            {
                <video class="details-main-img" src="@mediaList[0].FilePath"
                       controls muted playsinline style="cursor:default;background:#000"></video>
            }
            else
            {
                <img class="details-main-img"
                     src="@mediaList[0].FilePath"
                     alt="@p.Name"
                     onerror="this.src='/img/no-photo.svg'"
                     onclick="openLightbox(0)"
                     style="cursor:zoom-in" />
            }
            <div class="details-img-actions">
                <button class="details-img-btn" onclick="shareProduct(event)" title="Share">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="18" cy="5" r="3" /><circle cx="6" cy="12" r="3" /><circle cx="18" cy="19" r="3" /><line x1="8.59" y1="13.51" x2="15.42" y2="17.49" /><line x1="15.41" y1="6.51" x2="8.59" y2="10.49" /></svg>
                </button>
                <button class="details-img-btn @(false ? "product-card-action-active" : "")"
                        id="btnFav"
                        onclick="toggleFav(this, @p.Id, true)" title="Favourites">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z" /></svg>
                </button>
                <button class="details-img-btn @(false ? "product-card-action-active" : "")"
                        id="btnCart"
                        onclick="toggleFav(this, @p.Id, false)" title="Cart">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="9" cy="21" r="1" /><circle cx="20" cy="21" r="1" /><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6" /></svg>
                </button>
                <button class="details-img-btn" title="Report" onclick="openReportModal(@p.Id)">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z" /><line x1="12" y1="9" x2="12" y2="13" /><line x1="12" y1="17" x2="12.01" y2="17" /></svg>
                </button>
            </div>
        </div>


        <!-- Инфо -->
        <div class="details-info">
            @if (p.Price.HasValue)
            {
                <div class="details-price">@p.Price.Value.ToString("N2") €</div>
            }
            else
            {
                <div class="details-price" data-i18n="price_on_request">Price on request</div>
            }
            <h1 class="details-title">@p.Name</h1>
            <div class="details-meta">
                <span>@p.Address</span>
                <span>@(p.CreatedTime?.ToString("dd MMM, HH:mm"))</span>
            </div>

            <!-- Кнопки -->
            <div class="details-actions">
                <button class="details-btn details-btn-primary" onclick="openMessageModal()">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z" /></svg>
                    <span data-i18n="write_btn">Write</span>
                </button>
                <button class="details-btn details-btn-secondary" onclick="togglePhone(this)" data-phone="@p.Seller?.PhoneNumber">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13.1a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 2.45h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 10.1a16 16 0 0 0 6 6l1.27-.95a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 17.92z" /></svg>
                    <span data-i18n="call_btn">Call</span>
                </button>
            </div>

            <!-- Продавец -->
            <div class="details-seller" style="cursor:pointer">
                 <div class="details-seller-avatar">
                    @if (p.Seller?.AvatarPath != null)
                    {
                        <img src="@p.Seller?.AvatarPath" onerror="this.src='/img/no-photo.svg'" />
                    }
                    else
                    {
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#ccc" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" /><circle cx="12" cy="7" r="4" /></svg>
                    }
                </div>
                <div>
                    <div class="details-seller-name">@(p.Seller?.UserName ?? "Unknown")</div>
                    @if (p.Seller?.IsCompany == true)
                    {
                        <div class="seller-badge">Company</div>
                    }
                </div>
                <button class="details-btn details-btn-secondary"
                        onclick="openSellerModal('@p.Seller?.UserName', '@p.Seller?.AvatarPath', '@p.Seller?.PhoneNumber', @((p.Seller?.IsCompany == true).ToString().ToLower()), '@p.Seller?.Email', '@(p.Seller?.CreatedAt?.ToString("dd MMM yyyy"))', @(p.Seller?.Id ?? 0))" data-i18n="seller_show_contact">
                    <span data-i18n="seller_show_contact">Show contact</span>
                </button>
            </div>
        </div>
        <!-- Лайтбокс -->
        <div class="lb-overlay" id="lbOverlay" onclick="closeLightbox()"></div>
        <div class="lb" id="lb">
            <button class="lb-close-btn" onclick="closeLightbox()">✕</button>
            <div class="lb-topbar">
                <span class="lb-counter" id="lbCounter">1 / @mediaList.Count</span>
                <span class="lb-title">@p.Price?.ToString("N2") €&nbsp;&nbsp;@p.Name</span>
            </div>
            <div class="lb-body">
                <div class="lb-thumbs">
                    @for (int i = 0; i < mediaList.Count; i++)
                    {
                        if (mediaList[i].MediaType == "video")
                        {
                            <div class="lb-thumb @(i == 0 ? "lb-thumb-active" : "")"
                                 onclick="lbGoto(@i)"
                                 style="position:relative;background:#000;cursor:pointer">
                                <video src="@mediaList[i].FilePath"
                                       style="width:100%;height:100%;object-fit:cover" muted></video>
                                <div style="position:absolute;inset:0;display:flex;align-items:center;
                                    justify-content:center;color:#fff;font-size:18px;pointer-events:none">
                                    ▶
                                </div>
                            </div>
                        }
                        else
                        {
                            <img class="lb-thumb @(i == 0 ? "lb-thumb-active" : "")"
                                 src="@mediaList[i].FilePath"
                                 onclick="lbGoto(@i)"
                                 onerror="this.src='/img/no-photo.svg'" />
                        }
                    }
                </div>
                <div class="lb-main">
                    <button class="lb-arrow lb-prev" onclick="lbMove(-1)">‹</button>
                    <img class="lb-img" id="lbImg" src="@mediaList[0].FilePath" onerror="this.src='/img/no-photo.svg'" />
                    <button class="lb-arrow lb-next" onclick="lbMove(1)">›</button>
                </div>
            </div>
        </div>

        <script>
            const lbMedia = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
                                mediaList.Select(m => new { path = m.FilePath, type = m.MediaType })
                        ));
            let lbIndex = 0;

            function openLightbox(i) {
                lbGoto(i);
                document.getElementById('lbOverlay').classList.add('open');
                document.getElementById('lb').classList.add('open');
            }

            function closeLightbox() {
                // Останавливаем видео при закрытии
                document.getElementById('lbVideo')?.pause();
                document.getElementById('lbOverlay').classList.remove('open');
                document.getElementById('lb').classList.remove('open');
            }

            function lbGoto(i) {
                lbIndex = (i + lbMedia.length) % lbMedia.length;
                const item   = lbMedia[lbIndex];
                const lbMain = document.querySelector('.lb-main');

                // Убираем предыдущий элемент
                document.getElementById('lbImg')?.remove();
                document.getElementById('lbVideo')?.remove();

                if (item.type === 'video') {
                    const v = document.createElement('video');
                    v.id = 'lbVideo'; v.className = 'lb-img';
                    v.src = item.path; v.controls = true;
                    v.autoplay = true; v.muted = false;
                    lbMain.insertBefore(v, document.querySelector('.lb-next'));
                } else {
                    const img = document.createElement('img');
                    img.id = 'lbImg'; img.className = 'lb-img';
                    img.src = item.path;
                    img.onerror = () => img.src = '/img/no-photo.svg';
                    lbMain.insertBefore(img, document.querySelector('.lb-next'));
                }

                document.getElementById('lbCounter').textContent =
                    (lbIndex + 1) + ' / ' + lbMedia.length;
                document.querySelectorAll('.lb-thumb').forEach((t, idx) =>
                    t.classList.toggle('lb-thumb-active', idx === lbIndex));
            }

            function lbMove(dir) { lbGoto(lbIndex + dir); }

            document.addEventListener('keydown', e => {
                if (!document.getElementById('lb').classList.contains('open')) return;
                if (e.key === 'ArrowLeft')  lbMove(-1);
                if (e.key === 'ArrowRight') lbMove(1);
                if (e.key === 'Escape')     closeLightbox();
            });        </script>
    </div>

    <!-- Описание -->
    @if (p.Description != null)
    {
        <div class="details-section">
            <h2 class="details-section-title" data-i18n="description">Description</h2>
            <p class="details-description">@p.Description</p>
        </div>
    }
    @{
        var paramValues = (Dictionary<int, string>)ViewBag.ParamValues;
        var paramDefs = (List<Linkora.Models.Parameter>)ViewBag.ParamDefs;
        var visibleParams = paramDefs.Where(d => paramValues.ContainsKey(d.Param.Id)).ToList();
    }
    @if (visibleParams.Count > 0)
    {
        <div class="details-section">
            <h2 class="details-section-title" data-i18n="parameters">Parameters</h2>
            <div class="details-params">
                @foreach (var vm in visibleParams)
                {
                    var val = paramValues[vm.Param.Id];
                    <div class="details-param-row">
                        <span class="details-param-name">@vm.Param.Name</span>
                        <span class="details-param-value">
                            @if (vm.Param.Type == 3)
                            {
                                @(val == "true" ? "Yes" : "No")
                            }
                            else
                            {
                                @val
                            }
                        </span>
                    </div>
                }
            </div>
        </div>
    }
    <!-- Похожие товары -->
    @if (similar.Count > 0)
    {
        <div class="details-section">
            <h2 class="details-section-title" data-i18n="similar_listings">Similar listings</h2>
            <div class="listing-grid">
                @foreach (var s in similar)
                {
                    <a class="product-card" asp-controller="Product" asp-action="Details" asp-route-id="@s.Id">
                        <div class="product-card-img">
                            <img src="@(s.AvatarImagePath ?? "/img/no-photo.svg")" alt="@s.Name"
                                 onerror="this.src='/img/no-photo.svg'" />
                        </div>
                        <div class="product-card-body">
                            <div class="product-card-price">@(s.Price.HasValue? s.Price.Value.ToString("N2") + " €" : "Price on request")</div>
                            <div class="product-card-name">@s.Name</div>
                            <div class="product-card-address">@s.Address</div>
                            <div class="product-card-date">@(s.CreatedTime?.ToString("dd MMM, HH:mm"))</div>
                        </div>
                    </a>
                }
            </div>
        </div>
    }
</div>

<!-- Модалка "написать" -->
<div class="msg-modal-overlay" id="msgOverlay" onclick="closeMessageModal()"></div>
<div class="msg-modal" id="msgModal">
    <div class="msg-modal-header">
        <div class="msg-modal-seller">
            <div class="details-seller-avatar" style="width:48px;height:48px">
                @if (p.Seller?.AvatarPath != null)
                {
                    <img src="@p.Seller?.AvatarPath" onerror="this.src='/img/no-photo.svg'" />
                }
                else
                {
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#ccc" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" /><circle cx="12" cy="7" r="4" /></svg>
                }
            </div>
            <div>
                <div class="details-seller-name">@(p.Seller?.UserName ?? "Unknown")</div>
            </div>
        </div>
        <button class="msg-modal-close" onclick="closeMessageModal()">✕</button>
    </div>
    <textarea class="msg-modal-textarea" placeholder="Your message..." data-i18n-placeholder="msg_ph"></textarea>
    <div class="msg-modal-footer">
        <button class="details-btn details-btn-secondary" onclick="closeMessageModal()" data-i18n="cancel_btn">Cancel</button>
        <button class="details-btn details-btn-primary" onclick="sendMessageToSeller()" data-i18n="send_btn">Send</button>
    </div>
</div>

<div class="modal-overlay" id="reportOverlay" onclick="closeReportModal()"></div>
<div class="modal" id="reportModal">
    <button class="modal-close" onclick="closeReportModal()">✕</button>
    <h2 class="auth-title" data-i18n="report_title">Report listing</h2>
    <div class="auth-field">
        <label class="auth-label" data-i18n="report_reason_label">Reason</label>
        <select class="auth-input" id="reportReason">
            <option value="" data-i18n="report_reason_ph">Select a reason</option>
        </select>
    </div>
    <div class="auth-field">
        <label class="auth-label" data-i18n="report_comment_label">Comment (optional)</label>
        <textarea class="auth-input" id="reportComment" rows="3" placeholder="Additional details..." data-i18n-placeholder="report_comment_ph"></textarea>
    </div>
    <div class="auth-actions" style="display:flex; gap:12px;">
        <button class="auth-submit" onclick="submitReport()" data-i18n="send_report_btn">Send report</button>
        <button class="auth-submit auth-submit-secondary" onclick="closeReportModal()" data-i18n="cancel_btn">Cancel</button>
    </div>
</div>
<script>
    function openMessageModal() {
        document.getElementById('msgOverlay').classList.add('open');
        document.getElementById('msgModal').classList.add('open');
    }

    async function sendMessageToSeller() {
        const textarea = document.querySelector('.msg-modal-textarea');
        const text = textarea?.value.trim();
        if (!text) return;
        const res = await fetch('/Messages/Start', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
                productId: @p.Id,
                sellerId:  @(p.Seller?.Id ?? 0),
                text
            })
        });
        if (res.status === 401) { openAuthModal('login'); return; }
        const { conversationId } = await res.json();
        window.location.href = '/Messages/Index/' + conversationId;
    }
    function closeMessageModal() {
        document.getElementById('msgOverlay').classList.remove('open');
        document.getElementById('msgModal').classList.remove('open');
    }
    function togglePhone(btn) {
        const phone = btn.dataset.phone;
        if (!phone) { btn.textContent = 'No phone'; return; }
        if (btn.classList.contains('shown')) {
            btn.innerHTML = `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13.1a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 2.45h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 10.1a16 16 0 0 0 6 6l1.27-.95a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 17.92z"/></svg> Call`;
            btn.classList.remove('shown');
        } else {
            btn.textContent = phone;
            btn.classList.add('shown');
        }
    }
        document.addEventListener('DOMContentLoaded', async () => {
        const res = await fetch('/Favourite/UserItems');
        if (!res.ok) return;
        const { favs, cart } = await res.json();
        if (favs.includes(@p.Id)) document.getElementById('btnFav')?.classList.add('product-card-action-active');
        if (cart.includes(@p.Id)) document.getElementById('btnCart')?.classList.add('product-card-action-active');
    });

    function shareProduct(e) {
        navigator.clipboard.writeText(window.location.href).catch(() => {});
        const tip = document.createElement('div');
        tip.textContent = t('link_copied');
        tip.style.cssText = `
            position:fixed; left:${e.clientX + 12}px; top:${e.clientY - 8}px;
            background:#1a1a1a; color:#fff; font-size:13px;
            padding:6px 12px; border-radius:8px; pointer-events:none;
            z-index:9999; opacity:1; transition:opacity 0.3s;
        `;
        document.body.appendChild(tip);
        setTimeout(() => { tip.style.opacity = '0'; }, 600);
        setTimeout(() => tip.remove(), 600);
    }
        let reportReasons = [];

    async function openReportModal(productId) {
        if (!reportReasons.length) {
            const res = await fetch('/api/Report/reasons');
            if (!res.ok) return;
            reportReasons = await res.json();
        }
        const select = document.getElementById('reportReason');
        select.innerHTML = '<option value="">Select a reason</option>';
        reportReasons.forEach(r => {
            const opt = document.createElement('option');
            opt.value = r.id;
            opt.textContent = r.text;
            select.appendChild(opt);
        });
        document.getElementById('reportModal').dataset.productId = productId;
        document.getElementById('reportOverlay').classList.add('modal-open');
        document.getElementById('reportModal').classList.add('modal-open');
    }

    function closeReportModal() {
        document.getElementById('reportOverlay').classList.remove('modal-open');
        document.getElementById('reportModal').classList.remove('modal-open');
    }

    async function submitReport() {
        const reasonId = document.getElementById('reportReason').value;
        if (!reasonId) {
            alert('Please select a reason');
            return;
        }
        const comment = document.getElementById('reportComment').value;
        const productId = document.getElementById('reportModal').dataset.productId;

        const res = await fetch('/api/Report/create', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'RequestVerificationToken': document.getElementById('afToken')?.value ?? ''
            },
            body: JSON.stringify({
                productId: parseInt(productId),
                reportReasonId: parseInt(reasonId),
                comment: comment || null
            })
        });

        if (res.status === 401) {
            closeReportModal();
            openAuthModal('login');
            return;
        }

        if (res.ok) {
            alert('Report submitted. Thank you.');
            closeReportModal();
        } else {
            const err = await res.text();
            alert('Error: ' + err);
        }
    }
    </script>