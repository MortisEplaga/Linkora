@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Antiforgery
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Linkora</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Linkora.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/header.css" />
    <link rel="stylesheet" href="~/css/category.css" />
    <link rel="stylesheet" href="~/css/catmenu.css" />
    <link rel="stylesheet" href="~/css/create.css" />
    <link rel="stylesheet" href="~/css/auth.css" />
    <link rel="stylesheet" href="~/css/seller.css" />
    @await RenderSectionAsync("Styles", required: false)
    <!-- i18n must load before body renders to avoid flash -->
    <script src="~/js/i18n.js"></script>
</head>
<body>

    <input type="hidden" id="afToken" value="@Antiforgery.GetAndStoreTokens(Context).RequestToken" />

    @await Html.PartialAsync("CategoryMenu")

    <!-- Auth Modal -->
    <div class="modal-overlay" id="authOverlay" onclick="closeAuthModal()"></div>
    <div class="modal" id="authModal">
        <button class="modal-close" onclick="closeAuthModal()">✕</button>
        <div class="auth-tabs">
            <button class="auth-tab auth-tab-active" onclick="switchTab('login')" data-i18n="auth_sign_in">Sign in</button>
            <button class="auth-tab" onclick="switchTab('register')" data-i18n="auth_register">Register</button>
        </div>

        <div id="authError" class="auth-error" style="display:none"></div>

        <!-- Login -->
        <div id="tabLogin">
            <div class="auth-socials">
                <a class="auth-social auth-social-google" href="/Account/GoogleLogin?returnUrl=@Context.Request.Path"
                   title="Sign in with Google">
                    <svg width="18" height="18" viewBox="0 0 48 48">
                        <path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z" />
                        <path fill="#4285F4" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z" />
                        <path fill="#FBBC05" d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z" />
                        <path fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.18 1.48-4.97 2.36-8.16 2.36-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z" />
                        <path fill="none" d="M0 0h48v48H0z" />
                    </svg>
                </a>
            </div>
            <div class="auth-divider"><span data-i18n="auth_or">or</span></div>
            <div class="auth-field">
                <input type="text" class="auth-input" id="loginUsername"
                       placeholder="Username or email"
                       data-i18n-placeholder="auth_username_ph" />
            </div>
            <div class="auth-field auth-field-password">
                <input type="password" class="auth-input" id="loginPassword"
                       placeholder="Password"
                       data-i18n-placeholder="auth_password_ph" />
                <button type="button" class="auth-eye" onclick="togglePass('loginPassword',this)">👁</button>
            </div>
            <a class="auth-forgot" href="#" data-i18n="auth_forgot">Forgot password?</a>
            <button class="auth-submit" onclick="submitLogin()" data-i18n="auth_submit_login">Sign in</button>
        </div>

        <!-- Register -->
        <div id="tabRegister" style="display:none">
            <div class="auth-socials">
                <a class="auth-social auth-social-google" href="/Account/GoogleLogin"
                   title="Sign up with Google">
                    <svg width="18" height="18" viewBox="0 0 48 48">
                        <path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z" />
                        <path fill="#4285F4" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z" />
                        <path fill="#FBBC05" d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z" />
                        <path fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.18 1.48-4.97 2.36-8.16 2.36-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z" />
                        <path fill="none" d="M0 0h48v48H0z" />
                    </svg>
                </a>
            </div>
            <div class="auth-divider"><span data-i18n="auth_or">or</span></div>
            <div class="auth-type-row">
                <label class="auth-type-option">
                    <input type="radio" name="accType" value="private" checked />
                    <span class="auth-type-circle"></span>
                    <span data-i18n="auth_private">Private</span>
                </label>
                <label class="auth-type-option">
                    <input type="radio" name="accType" value="business" />
                    <span class="auth-type-circle"></span>
                    <span data-i18n="auth_business">Business</span>
                </label>
            </div>
            <div class="auth-type-hint" data-i18n="auth_type_hint">You won't be able to change this later.</div>
            <div class="auth-field">
                <input type="text" class="auth-input" id="regUsername" placeholder="Username" />
            </div>
            <div class="auth-field">
                <input type="email" class="auth-input" id="regEmail" placeholder="Email" />
            </div>
            <div class="auth-field auth-field-password">
                <input type="password" class="auth-input" id="regPassword"
                       placeholder="Password"
                       data-i18n-placeholder="auth_password_ph"
                       oninput="checkStrength(this)" />
                <button type="button" class="auth-eye" onclick="togglePass('regPassword',this)">👁</button>
            </div>
            <ul class="auth-rules">
                <li id="rule-len" data-i18n="auth_rule_len">At least 8 characters</li>
                <li id="rule-upper" data-i18n="auth_rule_upper">Uppercase letter</li>
                <li id="rule-lower" data-i18n="auth_rule_lower">Lowercase letter</li>
                <li id="rule-digit" data-i18n="auth_rule_digit">Digit</li>
            </ul>
            <div class="auth-field auth-field-password">
                <input type="password" class="auth-input" id="regConfirm"
                       placeholder="Confirm password"
                       data-i18n-placeholder="auth_confirm_ph" />
                <button type="button" class="auth-eye" onclick="togglePass('regConfirm',this)">👁</button>
            </div>
            <label class="auth-check-row">
                <input type="checkbox" id="chkTerms" />
                <span data-i18n="auth_terms">I accept the <a href="#">Terms of Service</a></span>
            </label>
            <button class="auth-submit" onclick="submitRegister()" data-i18n="auth_submit_register">Register</button>
        </div>
    </div>
    <!-- Hidden forms -->
    <form id="loginForm" method="post" action="/Account/Login" style="display:none">
        <input type="hidden" name="username" id="fLoginUsername" />
        <input type="hidden" name="password" id="fLoginPassword" />
        <input type="hidden" name="returnUrl" id="fLoginReturn" />
    </form>
    <form id="registerForm" method="post" action="/Account/Register" style="display:none">
        <input type="hidden" name="username" id="fRegUsername" />
        <input type="hidden" name="email" id="fRegEmail" />
        <input type="hidden" name="password" id="fRegPassword" />
        <input type="hidden" name="confirm" id="fRegConfirm" />
    </form>

    <!-- Region Modal -->
    <div class="modal-overlay" id="regionOverlay" onclick="closeRegionModal()"></div>
    <div class="modal" id="regionModal">
        <button class="modal-close" onclick="closeRegionModal()">✕</button>
        <h2 class="auth-title" data-i18n="region_title">Select region</h2>
        <div class="region-search-wrap">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#aaa" stroke-width="2"><circle cx="11" cy="11" r="8" /><line x1="21" y1="21" x2="16.65" y2="16.65" /></svg>
            <input type="text" class="region-search" id="regionSearch"
                   placeholder="Enter city"
                   data-i18n-placeholder="region_search_ph"
                   oninput="filterRegions(this.value)" />
        </div>
        <div class="region-pills" id="regionPills"></div>
    </div>

    <!-- Seller Modal -->
    <div class="modal-overlay" id="sellerOverlay" onclick="closeSellerModal()"></div>
    <div class="modal" id="sellerModal">
        <button class="modal-close" onclick="closeSellerModal()">✕</button>
        <div class="seller-modal-body">
            <div class="seller-modal-avatar" id="smAvatar"></div>
            <div class="seller-modal-name" id="smName"></div>
            <div id="smBadge"></div>
            <div class="seller-modal-stars" id="smRating" style="display:none"></div>
            <div class="seller-modal-row" id="smPhoneRow">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13.1a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 2.45h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 10.1a16 16 0 0 0 6 6l1.27-.95a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 17.92z" />
                </svg>
                <span id="smPhone"></span>
            </div>
            <div class="seller-modal-row" id="smEmailRow">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" />
                    <polyline points="22,6 12,13 2,6" />
                </svg>
                <span id="smEmail"></span>
            </div>
            <div class="seller-modal-row" id="smDateRow">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <rect x="3" y="4" width="18" height="18" rx="2" />
                    <line x1="16" y1="2" x2="16" y2="6" />
                    <line x1="8" y1="2" x2="8" y2="6" />
                    <line x1="3" y1="10" x2="21" y2="10" />
                </svg>
                <span id="smDate"></span>
            </div>
            <a class="seller-modal-link" id="smLink" data-i18n="seller_other_listings">Other listings →</a>
        </div>
    </div>

    @await Html.PartialAsync("Header")

    <div style="max-width:1280px; margin:0 auto; padding:0 24px;">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="site-footer">
        <div class="footer-inner">
            <div class="footer-links">
                <a href="#" onclick="openFaqModal(); return false;" class="footer-link">FAQ</a>
                <span class="footer-sep">·</span>
                <a href="#" onclick="openTermsModal(); return false;" class="footer-link">Terms of use</a>
                <span class="footer-sep">·</span>
                <a asp-area="" asp-controller="Home" asp-action="Privacy" class="footer-link" data-i18n="privacy">Privacy</a>
            </div>
            <div class="footer-copy">© 2026 Linkora</div>
        </div>
    </footer>

    <div class="modal-overlay" id="faqOverlay" onclick="closeFaqModal()"></div>
    <div class="modal info-modal" id="faqModal">
        <button class="modal-close" onclick="closeFaqModal()">✕</button>
        <h2 class="info-modal-title">FAQ</h2>

        <div class="info-modal-lang-tabs">
            <button class="info-lang-btn active" onclick="switchInfoLang('ru', this)">RU</button>
            <button class="info-lang-btn" onclick="switchInfoLang('lv', this)">LV</button>
        </div>

        <div class="info-modal-body">

            <div class="info-lang-content" data-lang="ru">
                <div class="faq-item">
                    <div class="faq-q" onclick="toggleFaq(this)">Как зарегистрироваться? <span class="faq-arrow">›</span></div>
                    <div class="faq-a">Нажав на раздел меню, найдите возможность «Зарегистрироваться», после чего откроется бланк, заполнив который вы станете зарегистрированным пользователем. При размещении поста вам потребуется активировать контактную информацию.</div>
                </div>
                <div class="faq-item">
                    <div class="faq-q" onclick="toggleFaq(this)">Можно ли пользоваться порталом, будучи незарегистрированным пользователем? <span class="faq-arrow">›</span></div>
                    <div class="faq-a">Незарегистрированный пользователь может просматривать размещенные посты и добавлять их в разделы «Любимое» и «Корзина»; они будут сохранены после регистрации или подключения к своему профилю.</div>
                </div>
                <div class="faq-item">
                    <div class="faq-q" onclick="toggleFaq(this)">Как активировать номер телефона и адрес электронной почты? <span class="faq-arrow">›</span></div>
                    <div class="faq-a">Зайдя в раздел «Мой профиль», вы найдете подраздел «Мои данные», где можно активировать или изменить контактную информацию.</div>
                </div>
                <div class="faq-item">
                    <div class="faq-q" onclick="toggleFaq(this)">Как изменить пароль? <span class="faq-arrow">›</span></div>
                    <div class="faq-a">Зайдя в раздел «Мой профиль», вы найдете подраздел «Изменение пароля», где можно изменить действующий пароль.</div>
                </div>
                <div class="faq-item">
                    <div class="faq-q" onclick="toggleFaq(this)">Как сохранить посты, которые я искал (-а)? <span class="faq-arrow">›</span></div>
                    <div class="faq-a">Интересующие вас посты можно сохранить, нажав на иконку «Добавить в Любимое». Позднее вы найдете их в разделе «Любимое».</div>
                </div>
                <div class="faq-item">
                    <div class="faq-q" onclick="toggleFaq(this)">Как отслеживать появление новых интересующих меня постов? <span class="faq-arrow">›</span></div>
                    <div class="faq-a">Список постов можно фильтровать по желаемым параметрам, а также отметить, чтобы мы сообщали вам о появлении новинок по данному фильтру.</div>
                </div>
                <div class="faq-item">
                    <div class="faq-q" onclick="toggleFaq(this)">Через какое время мой пост будет утвержден? <span class="faq-arrow">›</span></div>
                    <div class="faq-a">Пост размещается на портале незамедлительно. Пост должен соответствовать правилам портала, в противном случае он будет заблокирован.</div>
                </div>
                <div class="faq-item">
                    <div class="faq-q" onclick="toggleFaq(this)">Как долго будет активен размещенный пост? <span class="faq-arrow">›</span></div>
                    <div class="faq-a">Срок публикации каждого размещенного поста составляет 1 месяц с момента публикации. После окончания срока вы можете повторно разместить данный пост.</div>
                </div>
                <div class="faq-item">
                    <div class="faq-q" onclick="toggleFaq(this)">Как редактировать содержание поста? <span class="faq-arrow">›</span></div>
                    <div class="faq-a">Все содержание поста можно редактировать перед публикацией. После публикации цену разрешается редактировать не более трёх раз, а изображения и видео — без ограничений.</div>
                </div>
                <div class="faq-item">
                    <div class="faq-q" onclick="toggleFaq(this)">Как редактировать цену, указанную в опубликованном посте? <span class="faq-arrow">›</span></div>
                    <div class="faq-a">Открыв соответствующий пост, вы найдете кнопку «Редактировать», после нажатия которой сможете исправить цену.</div>
                </div>
                <div class="faq-item">
                    <div class="faq-q" onclick="toggleFaq(this)">Что делать, если пост заблокирован? <span class="faq-arrow">›</span></div>
                    <div class="faq-a">В случае блокировки поста его владелец получит по электронной почте сообщение с указанием причины блокировки. Вы можете отредактировать данный пост и отправить его на повторное рассмотрение.</div>
                </div>
                <div class="faq-item">
                    <div class="faq-q" onclick="toggleFaq(this)">Можно ли изменить или добавить в пост изображения и видео? <span class="faq-arrow">›</span></div>
                    <div class="faq-a">Проверьте размеры и формат фотографий и видео. Если они не соответствуют требованиям и разместить их не удается, просим обратиться к администрации.</div>
                </div>
                <div class="faq-item">
                    <div class="faq-q" onclick="toggleFaq(this)">Как удалить пост? <span class="faq-arrow">›</span></div>
                    <div class="faq-a">Открыв меню возле соответствующего поста, вы найдете возможность «Удалить».</div>
                </div>
            </div>

            <div class="info-lang-content" data-lang="lv" style="display:none">
                <div class="faq-item">
                    <div class="faq-q" onclick="toggleFaq(this)">Kā reģistrēties? <span class="faq-arrow">›</span></div>
                    <div class="faq-a">Nospiežot uz izvēlnes sadaļas, atrodiet iespēju "Reģistrēties", pēc tam atvērsies forma, kuru aizpildot jūs kļūsiet par reģistrētu lietotāju. Publicējot sludinājumu, jums būs jāaktivizē kontaktinformācija.</div>
                </div>
                <div class="faq-item">
                    <div class="faq-q" onclick="toggleFaq(this)">Vai portālu var izmantot nereģistrēts lietotājs? <span class="faq-arrow">›</span></div>
                    <div class="faq-a">Nereģistrēts lietotājs var apskatīt publicētos sludinājumus un pievienot tos sadaļām "Izlase" un "Grozs"; tie tiks saglabāti pēc reģistrācijas vai pieslēgšanās savam profilam.</div>
                </div>
                <div class="faq-item">
                    <div class="faq-q" onclick="toggleFaq(this)">Kā aktivizēt tālruņa numuru un e-pasta adresi? <span class="faq-arrow">›</span></div>
                    <div class="faq-a">Atverot sadaļu "Mans profils", jūs atradīsiet apakšsadaļu "Mani dati", kur var aktivizēt vai mainīt kontaktinformāciju.</div>
                </div>
                <div class="faq-item">
                    <div class="faq-q" onclick="toggleFaq(this)">Kā nomainīt paroli? <span class="faq-arrow">›</span></div>
                    <div class="faq-a">Atverot sadaļu "Mans profils", jūs atradīsiet apakšsadaļu "Paroles maiņa", kur var mainīt esošo paroli.</div>
                </div>
                <div class="faq-item">
                    <div class="faq-q" onclick="toggleFaq(this)">Kā saglabāt sludinājumus, kurus es meklēju? <span class="faq-arrow">›</span></div>
                    <div class="faq-a">Jūs interesējošos sludinājumus var saglabāt, nospiežot ikonu "Pievienot izlasei". Vēlāk jūs tos atradīsiet sadaļā "Izlase".</div>
                </div>
                <div class="faq-item">
                    <div class="faq-q" onclick="toggleFaq(this)">Kā sekot līdzi jaunu sludinājumu parādīšanās? <span class="faq-arrow">›</span></div>
                    <div class="faq-a">Sludinājumu sarakstu var filtrēt pēc vēlamajiem parametriem, kā arī atzīmēt, lai mēs jūs informētu par jaunumiem atbilstoši šim filtram.</div>
                </div>
                <div class="faq-item">
                    <div class="faq-q" onclick="toggleFaq(this)">Cik ātri mans sludinājums tiks apstiprināts? <span class="faq-arrow">›</span></div>
                    <div class="faq-a">Sludinājums tiek publicēts nekavējoties. Tam jāatbilst portāla noteikumiem, pretējā gadījumā tas tiks bloķēts.</div>
                </div>
                <div class="faq-item">
                    <div class="faq-q" onclick="toggleFaq(this)">Cik ilgi publicētais sludinājums būs aktīvs? <span class="faq-arrow">›</span></div>
                    <div class="faq-a">Katra sludinājuma publicēšanas termiņš ir 1 mēnesis no publicēšanas brīža. Pēc termiņa beigām jūs varat to publicēt atkārtoti.</div>
                </div>
                <div class="faq-item">
                    <div class="faq-q" onclick="toggleFaq(this)">Kā rediģēt sludinājuma saturu? <span class="faq-arrow">›</span></div>
                    <div class="faq-a">Visu sludinājuma saturu var rediģēt pirms publicēšanas; pēc tam cenu drīkst rediģēt ne vairāk kā trīs reizes, bet attēlus un video – bez ierobežojumiem.</div>
                </div>
                <div class="faq-item">
                    <div class="faq-q" onclick="toggleFaq(this)">Kā rediģēt publicētajā sludinājumā norādīto cenu? <span class="faq-arrow">›</span></div>
                    <div class="faq-a">Atverot attiecīgo sludinājumu, jūs atradīsiet pogu "Rediģēt", pēc kuras nospiešanas varēsiet veikt labojumus.</div>
                </div>
                <div class="faq-item">
                    <div class="faq-q" onclick="toggleFaq(this)">Ko darīt, ja sludinājums ir bloķēts? <span class="faq-arrow">›</span></div>
                    <div class="faq-a">Bloķēšanas gadījumā sludinājuma īpašnieks saņems e-pasta ziņojumu ar bloķēšanas iemeslu. Jūs varat rediģēt sludinājumu un nosūtīt to atkārtotai pārskatīšanai.</div>
                </div>
                <div class="faq-item">
                    <div class="faq-q" onclick="toggleFaq(this)">Vai var mainīt vai pievienot sludinājumam attēlus un video? <span class="faq-arrow">›</span></div>
                    <div class="faq-a">Pārbaudiet attēlu un video izmērus un formātu; ja tie neatbilst prasībām un tos nevar augšupielādēt, lūdzam sazināties ar administrāciju.</div>
                </div>
                <div class="faq-item">
                    <div class="faq-q" onclick="toggleFaq(this)">Kā dzēst sludinājumu? <span class="faq-arrow">›</span></div>
                    <div class="faq-a">Atverot izvēlni pie attiecīgā sludinājuma, jūs atradīsiet iespēju "Dzēst".</div>
                </div>
            </div>

        </div>
    </div>

    <div class="modal-overlay" id="termsOverlay" onclick="closeTermsModal()"></div>
    <div class="modal info-modal" id="termsModal">
