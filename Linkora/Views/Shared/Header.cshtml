<header class="site-header">

    @* ── Верхняя навигационная полоса ── *@
    <div class="header-nav sticky-top" id="header-nav">
        <nav class="navbar">
            <div class="navbar-inner">


                @* Offcanvas-меню *@
                <div class="offcanvas offcanvas-start" id="offcanvasMenu" tabindex="-1">
                    <div class="offcanvas-header">
                        <h5 class="offcanvas-title">Меню</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Закрыть"></button>
                    </div>
                    <div class="offcanvas-body">
                        <ul class="nav-links">
                            <li><a class="nav-link" asp-controller="Home" asp-action="Index">For business</a></li>
                            <li><a class="nav-link" asp-controller="Home" asp-action="Index">Career</a></li>
                            <li><a class="nav-link" asp-controller="Home" asp-action="Index">Help</a></li>

                            @if (User.IsInRole("Admin"))
                            {
                                <li><a class="nav-link" asp-controller="Home" asp-action="Index" asp-area="Administrator">Admin panel</a></li>
                            }
                            @if (User.IsInRole("User"))
                            {
                                <li><a class="nav-link" asp-controller="Account" asp-action="Index">My account</a></li>
                            }
                        </ul>
                    </div>
                </div>

                <div class="header-actions">
                    @if (User.Identity!.IsAuthenticated)
                    {
                        <div class="user-menu-wrap">
                            @{
                                var avatarPath = User.FindFirst("Avatar")?.Value;
                            }
                            <button class="login-btn" onclick="toggleUserMenu()">
                                @if (avatarPath != null)
                                {
                                    <img src="@avatarPath" class="header-user-avatar" />
                                }
                                else
                                {
                                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24"
                                         fill="none" stroke="currentColor" stroke-width="2"
                                         stroke-linecap="round" stroke-linejoin="round">
                                        <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
                                        <circle cx="12" cy="7" r="4" />
                                    </svg>
                                }
                                @User.Identity.Name
                            </button>                            <div class="user-dropdown" id="userDropdown">
                                <div class="user-dropdown-name">@User.Identity.Name</div>
                                <div class="user-dropdown-divider"></div>
                                <a class="user-dropdown-item" asp-controller="Product" asp-action="My">
                                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7" /><rect x="14" y="3" width="7" height="7" /><rect x="3" y="14" width="7" height="7" /><rect x="14" y="14" width="7" height="7" /></svg>
                                    My ads
                                </a>
                                <a class="user-dropdown-item" href="/Messages/Index">
                                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z" />
                                    </svg>
                                    Messages
                                    <span class="msg-nav-badge" id="msgNavBadge" style="display:none;margin-left:auto"></span>
                                </a>
                                <a class="user-dropdown-item" asp-controller="Favourite" asp-action="Index" asp-route-tab="favs">
                                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z" /></svg>
                                    Favourites
                                    <span class="msg-nav-badge" id="favsNavBadge" style="display:none; margin-left:auto"></span>
                                </a>
                                <a class="user-dropdown-item" href="#">
                                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2" /></svg>
                                    Reviews
                                </a>
                                <div class="user-dropdown-divider"></div>
                                <a class="user-dropdown-item" asp-controller="Favourite" asp-action="Index" asp-route-tab="cart">
                                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="9" cy="21" r="1" /><circle cx="20" cy="21" r="1" /><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6" /></svg>
                                    Cart
                                    <span class="msg-nav-badge" id="cartNavBadge" style="display:none; margin-left:auto"></span>
                                </a>
                                <a class="user-dropdown-item" href="#">
                                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z" /><line x1="3" y1="6" x2="21" y2="6" /><path d="M16 10a4 4 0 0 1-8 0" /></svg>
                                    Orders
                                </a>                               
                                <div class="user-dropdown-divider"></div>
                                <a class="user-dropdown-item" href="#">
                                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3" /><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z" /></svg>
                                    Settings
                                </a>
                                <a class="user-dropdown-item user-dropdown-logout" asp-controller="Account" asp-action="Logout">
                                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4" /><polyline points="16 17 21 12 16 7" /><line x1="21" y1="12" x2="9" y2="12" /></svg>
                                    Logout
                                </a>
                            </div>
                        </div>
                    }
                    else
                    {
                        <button class="login-btn" onclick="openAuthModal('login')">
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24"
                                 fill="none" stroke="currentColor" stroke-width="2"
                                 stroke-linecap="round" stroke-linejoin="round">
                                <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
                                <circle cx="12" cy="7" r="4" />
                            </svg>
                            Sign in
                        </button>
                    }
                    @*
                    После переноса Identity — раскомментировать:

                    @if (User.Identity.IsAuthenticated)
                    {
                        <div class="user-menu">
                            @await Component.InvokeAsync("Avatar")
                            <button class="user-menu-toggle dropdown-toggle" type="button"
                                    data-bs-toggle="dropdown" aria-expanded="false">
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end">
                                <li><a class="dropdown-item" asp-controller="Account" asp-action="Index">Account (@User.Identity.Name)</a></li>
                                <li><a class="dropdown-item" asp-controller="Authorization" asp-action="Logout">Logout</a></li>
                            </ul>
                        </div>
                    }
                    else
                    {
                        <a asp-controller="Authorization" asp-action="Login" class="login-btn">Login / Register</a>
                    }
                    *@

                </div>

            </div>
        </nav>
    </div>

    @* ── Средняя полоса: логотип + поиск ── *@
    <div class="header-search-bar">
        <div class="header-search-inner">

            @* Логотип *@
            <a asp-controller="Home" asp-action="Index" class="site-logo">
                <img src="/img/Logo.svg" alt="Linkora24" width="175" />
            </a>

            @* Кнопка «Все категории» *@
            <button type="button" class="categories-btn" onclick="openCatMenu()">
                <img src="/img/search_for.svg" alt="" class="categories-icon" />
                All categories
            </button>

            @* Поиск *@
            <form asp-controller="Product" asp-action="Search" class="search-form">
                <div class="search-pill">
                    <input type="text" class="search-input"
                           name="search"
                           placeholder="Search..."
                           aria-label="Search" />
                    <button type="submit" class="search-btn">Search</button>
                </div>
            </form>

            <a asp-controller="Product" asp-action="Create" class="header-post-btn">
                + Post an ad
            </a>

        </div>
    </div>
</header>
