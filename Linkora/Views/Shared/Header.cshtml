<header class="site-header">

    @* ── Top navigation bar ── *@
    <div class="header-nav sticky-top" id="header-nav">
        <nav class="navbar">
            <div class="navbar-inner">

                <div class="offcanvas offcanvas-start" id="offcanvasMenu" tabindex="-1">
                    <div class="offcanvas-header">
                        <h5 class="offcanvas-title" data-i18n="my_ads">Menu</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Close"></button>
                    </div>
                    <div class="offcanvas-body">
                        <ul class="nav-links">
                            <li><a class="nav-link" asp-controller="Home" asp-action="Index" data-i18n="for_business">For business</a></li>
                            <li><a class="nav-link" asp-controller="Home" asp-action="Index" data-i18n="career">Career</a></li>
                            <li><a class="nav-link" asp-controller="Home" asp-action="Index" data-i18n="help">Help</a></li>
                        </ul>
                    </div>
                </div>

                <div class="header-actions">
                    @if (User.Identity!.IsAuthenticated)
                    {
                        <div class="user-menu-wrap">
                            @{
                                var avatarPath = User.FindFirst("Avatar")?.Value;
                            }
                            <button class="login-btn" onclick="toggleUserMenu()">
                                @if (avatarPath != null)
                                {
                                    <img src="@avatarPath" class="header-user-avatar" />
                                }
                                else
                                {
                                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24"
                                         fill="none" stroke="currentColor" stroke-width="2"
                                         stroke-linecap="round" stroke-linejoin="round">
                                        <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
                                        <circle cx="12" cy="7" r="4" />
                                    </svg>
                                }
                                @User.Identity.Name
                                </button>
                            <div class="user-dropdown" id="userDropdown">
                                <div class="user-dropdown-header">
                                    <div class="user-dropdown-name">@User.Identity.Name</div>
                                    <div class="notif-wrap" id="notifWrap">
                                        <button class="login-btn notif-bell-btn" onclick="toggleNotifDropdown(event)" title="Notifications">
                                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9" />
                                                <path d="M13.73 21a2 2 0 0 1-3.46 0" />
                                            </svg>
                                            <span class="notif-badge" id="notifBadge" style="display:none"></span>
                                        </button>
                                        <div class="notif-dropdown" id="notifDropdown">
                                            <div class="notif-header">
                                                <span>Notifications</span>
                                                <button class="notif-mark-all" onclick="markAllRead()">Mark all read</button>
                                            </div>
                                            <div class="notif-list" id="notifList">
                                                <div class="notif-empty">Loading...</div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="user-dropdown-divider"></div>
                                <a class="user-dropdown-item" asp-controller="Product" asp-action="My">
                                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7" /><rect x="14" y="3" width="7" height="7" /><rect x="3" y="14" width="7" height="7" /><rect x="14" y="14" width="7" height="7" /></svg>
                                    <span data-i18n="my_ads">My ads</span>
                                </a>
                                <a class="user-dropdown-item" href="/Messages/Index">
                                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z" />
                                    </svg>
                                    <span data-i18n="messages">Messages</span>
                                    <span class="msg-nav-badge" id="msgNavBadge" style="display:none;margin-left:auto"></span>
                                </a>
                                <a class="user-dropdown-item" asp-controller="Favourite" asp-action="Index" asp-route-tab="favs">
                                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z" /></svg>
                                    <span data-i18n="favourites">Favourites</span>
                                    <span class="msg-nav-badge" id="favsNavBadge" style="display:none;margin-left:auto"></span>
                                </a>
                                <a class="user-dropdown-item" href="/Subscription/Index">
                                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z" />
                                    </svg>
                                    <span>My subscriptions</span>
                                </a>
                                <a class="user-dropdown-item" onclick="openMyReviewsModal()" style="cursor:pointer">
                                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2" />
                                    </svg>
                                    <span data-i18n="reviews">Reviews</span>
                                </a>
                                <div class="user-dropdown-divider"></div>
                                <a class="user-dropdown-item" asp-controller="Favourite" asp-action="Index" asp-route-tab="cart">
                                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="9" cy="21" r="1" /><circle cx="20" cy="21" r="1" /><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6" /></svg>
                                    <span data-i18n="cart">Cart</span>
                                    <span class="msg-nav-badge" id="cartNavBadge" style="display:none;margin-left:auto"></span>
                                </a>
                                <div class="user-dropdown-divider"></div>
                                <a class="user-dropdown-item" onclick="openSettingsModal()" style="cursor:pointer">
                                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <circle cx="12" cy="12" r="3" />
                                        <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z" />
                                    </svg>
                                    <span data-i18n="settings">Settings</span>
                                </a>
                                <a class="user-dropdown-item user-dropdown-logout" asp-controller="Account" asp-action="Logout">
                                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4" /><polyline points="16 17 21 12 16 7" /><line x1="21" y1="12" x2="9" y2="12" /></svg>
                                    <span data-i18n="logout">Logout</span>
                                </a>
                            </div>
                        </div>
                    }
                    else
                    {
                        <button class="login-btn" onclick="openAuthModal('login')">
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24"
                                 fill="none" stroke="currentColor" stroke-width="2"
                                 stroke-linecap="round" stroke-linejoin="round">
                                <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
                                <circle cx="12" cy="7" r="4" />
                            </svg>
                            <span data-i18n="sign_in_btn">Sign in</span>
                        </button>
                    }
                </div>

            </div>
        </nav>
    </div>

    @* ── Search bar ── *@
    <div class="header-search-bar">
        <div class="header-search-inner">

            <a asp-controller="Home" asp-action="Index" class="site-logo">
                <img src="/img/Logo.svg" alt="Linkora24" width="175" />
            </a>

            <button type="button" class="categories-btn" onclick="openCatMenu()">
                <img src="/img/search_for.svg" alt="" class="categories-icon" />
                <span data-i18n="all_categories">All categories</span>
            </button>

            <form class="search-form" onsubmit="handleGlobalSearch(event)">
                <div class="search-pill">
                    <input type="text" class="search-input"
                           name="search"
                           placeholder="Search..."
                           data-i18n-placeholder="search_placeholder"
                           aria-label="Search" />
                    <button type="submit" class="search-btn" data-i18n="search_btn">Search</button>
                </div>
            </form>

            <a asp-controller="Product" asp-action="Create" class="header-post-btn">
                <span data-i18n="post_ad_btn">+ Post an ad</span>
            </a>

        </div>
    </div>

    @if (User.Identity!.IsAuthenticated)
    {
        <!-- Settings Modal -->
        <div class="modal-overlay" id="settingsOverlay" onclick="closeSettingsModal()"></div>
        <div class="modal" id="settingsModal" style="max-width:360px;width:360px;height:auto;min-height:unset;padding-bottom:24px">
            <button class="modal-close" onclick="closeSettingsModal()">✕</button>
            <h2 class="auth-title" data-i18n="settings_title">Settings</h2>

            <div class="settings-section">
                <div class="settings-label">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
                    </svg>
                    <span data-i18n="settings_dark">Dark mode</span>
                </div>
                <button class="settings-toggle" id="themeToggle" onclick="toggleTheme()">
                    <span class="settings-toggle-knob"></span>
                </button>
            </div>

            <div class="settings-section">
                <div class="settings-label">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <circle cx="12" cy="12" r="10" />
                        <line x1="2" y1="12" x2="22" y2="12" />
                        <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z" />
                    </svg>
                    <span data-i18n="settings_language">Language</span>
                </div>
                <div class="settings-lang-pills">
                    <button class="settings-lang-pill" id="langEN" onclick="setLang('en')">EN</button>
                    <button class="settings-lang-pill" id="langLV" onclick="setLang('lv')">LV</button>
                </div>
            </div>
        </div>

        <!-- Reviews Modal -->
        <div class="reviews-overlay" id="myReviewsOverlay" onclick="closeMyReviewsModal()"></div>
        <div class="reviews-modal" id="myReviewsModal">
            <div class="reviews-modal-header">
                <span class="reviews-modal-title" data-i18n="reviews_title">Reviews</span>
                <button class="reviews-modal-close" onclick="closeMyReviewsModal()">✕</button>
            </div>
            <div class="reviews-tabs">
                <button class="reviews-tab reviews-tab-active" id="tabAboutMe"
                        onclick="switchReviewTab('about')"
                        data-i18n="about_me_tab">
                    About me
                </button>
                <button class="reviews-tab" id="tabFromMe"
                        onclick="switchReviewTab('from')"
                        data-i18n="from_me_tab">
                    From me
                </button>
            </div>
            <div class="reviews-list" id="myReviewsList">
                <div class="reviews-empty" data-i18n="loading_text">Loading...</div>
            </div>
        </div>

        <script>
                        let notifOpen = false;

            async function toggleNotifDropdown(e) {
                e.stopPropagation();
                const drop = document.getElementById('notifDropdown');
                notifOpen = !notifOpen;
                drop.classList.toggle('open', notifOpen);
                if (notifOpen) await loadNotifications();
            }

            document.addEventListener('click', e => {
                if (!e.target.closest('#notifWrap')) {
                    document.getElementById('notifDropdown')?.classList.remove('open');
                    notifOpen = false;
                }
            });

            async function loadNotifications() {
                const list = document.getElementById('notifList');
                try {
                    const res = await fetch('/Notifications/List');
                    const data = await res.json();
                    if (!data.length) {
                        list.innerHTML = '<div class="notif-empty">No notifications</div>';
                        return;
                    }
                    list.innerHTML = data.map(n => `
                        <a class="notif-item ${n.isRead ? '' : 'unread'}"
                           href="${n.productId ? '/Product/Details/' + n.productId : '#'}"
                           onclick="markRead(${n.id})">
                            <img class="notif-item-avatar"
                                 src="${n.fromUserAvatar || '/img/no-photo.svg'}"
                                 onerror="this.src='/img/no-photo.svg'" />
                            <div class="notif-item-body">
                                <div class="notif-item-msg">${n.message}</div>
                                <div class="notif-item-time">${n.createdAt}</div>
                            </div>
                        </a>`
                    ).join('');
                    updateNotifBadge(data.filter(n => !n.isRead).length);
                } catch {
                    list.innerHTML = '<div class="notif-empty">Failed to load</div>';
                }
            }

            async function markRead(id) {
                await fetch(`/Notifications/MarkRead?id=${id}`, { method: 'POST' });
            }

            async function markAllRead() {
                await fetch('/Notifications/MarkAllRead', { method: 'POST' });
                document.querySelectorAll('.notif-item.unread').forEach(el => el.classList.remove('unread'));
                updateNotifBadge(0);
            }

            function updateNotifBadge(count) {
                const badge = document.getElementById('notifBadge');
                if (!badge) return;
                badge.textContent = count;
                badge.style.display = count > 0 ? 'flex' : 'none';
            }
            // ── Settings ──
            function openSettingsModal() {
                document.getElementById('userDropdown')?.classList.remove('open');
                applySettingsUI();
                document.getElementById('settingsOverlay').classList.add('modal-open');
                document.getElementById('settingsModal').classList.add('modal-open');
                applyTranslations();
            }
            function closeSettingsModal() {
                document.getElementById('settingsOverlay').classList.remove('modal-open');
                document.getElementById('settingsModal').classList.remove('modal-open');
            }
            function applySettingsUI() {
                const dark = localStorage.getItem('theme') === 'dark';
                document.getElementById('themeToggle').classList.toggle('settings-toggle-on', dark);
                const lang = localStorage.getItem('lang') || 'en';
                document.getElementById('langEN').classList.toggle('settings-lang-pill-active', lang === 'en');
                document.getElementById('langLV').classList.toggle('settings-lang-pill-active', lang === 'lv');
            }
            function toggleTheme() {
                const isDark = document.documentElement.classList.toggle('dark-theme');
                localStorage.setItem('theme', isDark ? 'dark' : 'light');
                document.getElementById('themeToggle').classList.toggle('settings-toggle-on', isDark);
            }
            function setLang(lang) {
                localStorage.setItem('lang', lang);
                document.cookie = `lang=${lang};path=/;max-age=31536000`;
                applyTranslations();
                document.getElementById('langEN').classList.toggle('settings-lang-pill-active', lang === 'en');
                document.getElementById('langLV').classList.toggle('settings-lang-pill-active', lang === 'lv');
                // Re-apply all translations on the page
                applyTranslations();
                // Refresh region button label if 'All regions' is shown
                const regionBtnLabel = document.getElementById('regionBtnLabel');
                if (regionBtnLabel && (regionBtnLabel.textContent === 'All regions' || regionBtnLabel.textContent === 'Visi reģioni')) {
                    regionBtnLabel.textContent = t('all_regions');
                }
            }

            // Apply theme on load
            (function() {
                if (localStorage.getItem('theme') === 'dark')
                    document.documentElement.classList.add('dark-theme');
            })();

            // ── Reviews ──
            async function openMyReviewsModal() {
                document.getElementById('userDropdown')?.classList.remove('open');
                document.getElementById('myReviewsOverlay').classList.add('open');
                document.getElementById('myReviewsModal').classList.add('open');
                applyTranslations();
                await loadReviewTab('about');
            }
            function closeMyReviewsModal() {
                document.getElementById('myReviewsOverlay').classList.remove('open');
                document.getElementById('myReviewsModal').classList.remove('open');
            }
            async function switchReviewTab(tab) {
                document.getElementById('tabAboutMe').classList.toggle('reviews-tab-active', tab === 'about');
                document.getElementById('tabFromMe').classList.toggle('reviews-tab-active', tab === 'from');
                await loadReviewTab(tab);
            }
            async function loadReviewTab(tab) {
                const list = document.getElementById('myReviewsList');
                list.innerHTML = `<div class="reviews-empty">${t('loading_text')}</div>`;
                try {
                    const res  = await fetch(`/Reviews/My?tab=${tab}`);
                    const data = await res.json();
                    if (!data.length) {
                        list.innerHTML = `<div class="reviews-empty">${t('no_reviews_yet')}</div>`;
                        return;
                    }
                    list.innerHTML = data.map(r => `
                        <div class="review-item">
                            <div class="review-author">
                                <img src="${r.avatarPath || '/img/no-photo.svg'}"
                                     class="review-author-avatar"
                                     onerror="this.src='/img/no-photo.svg'" />
                                <div>
                                    <a class="review-author-name" href="/Seller/Index/${r.userId}"
                                       onclick="closeMyReviewsModal()">
                                        ${r.userName}
                                    </a>
                                    <div class="review-date">${r.createdAt}</div>
                                </div>
                            </div>
                            <div class="review-stars">
                                ${[1,2,3,4,5].map(i =>
                                    `<svg width="14" height="14" viewBox="0 0 24 24"
                                          fill="${i <= r.rating ? '#f5a623' : 'none'}"
                                          stroke="#f5a623" stroke-width="2">
                                        <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
                                     </svg>`
                                ).join('')}
                            </div>
                            ${r.comment ? `<div class="review-comment">${r.comment}</div>` : ''}
                        </div>`
                    ).join('');
                } catch {
                    list.innerHTML = `<div class="reviews-empty">${t('failed_load')}</div>`;
                }
            }
                        function handleGlobalSearch(e) {
                e.preventDefault();
                const input = e.target.querySelector('.search-input');
                const q = input?.value.trim();
                if (!q) return;

                // Если уже на странице категории — добавляем q к текущему URL
                const match = window.location.pathname.match(/\/Category\/Index\/(\d+)/i);
                if (match) {
                    const url = new URL(window.location.href);
                    url.searchParams.set('q', q);
                    window.location.href = url.toString();
                } else {
                    // Иначе — идём на корневую категорию с поиском
                    window.location.href = '/Category/Index/3711?q=' + encodeURIComponent(q);
                }
            }
        </script>
    }
</header>
